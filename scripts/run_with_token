#!/usr/bin/pagsh
#
# PLEASE NOTE:
# We are running in 'sh' mode. BASH extensions are *not* available!
#
keytab="${HOME}/.keytab"
PRINCIPAL_NAME='svcusr-amas_regr@D.PSI.CH'

mydir=$(dirname "$0")
mydir=$(cd "${mydir}" && pwd)


usage() {
	echo "$(basename $0) PROG [ARGS...]" 1>&2
	exit 1
}

main() {
	(( $# == 0 )) && usage
	
	prog="$1"
	shift
	if [ ! -x "${prog}" ]; then
		echo "${prog}: does not exist or is not executable!" 1>&2
		exit 1
	fi
	if [ ! -r "${keytab}" ]; then
		echo "Keytab '${keytab}' does not exist or is not readable!'" 1>&2
		exit 1
	fi
	export KRB5CCNAME=$(mktemp /tmp/krb5cc_$(id -u)_XXXXXX)
	/usr/bin/kinit -t "${keytab}" -k "${PRINCIPAL_NAME}"	|| exit 2
	/usr/bin/aklog						|| exit 2

	"${prog}" "$@"

	/usr/bin/unlog
	/usr/bin/kdestroy
}

main "$@"

