#!/bin/bash

declare -r bindir=$(dirname "$0")
declare -a cmake_args=()
declare -a opal_args=()

#-----------------------------------------------------------------------------
# configuration
#

#
# repositories for sources and regression-tests
#
declare -r src_repo_url='https://gitlab.psi.ch/OPAL/src.git'
declare -r tests_repo_url='https://gitlab.psi.ch/OPAL/regression-tests.git'

#
# branch to use (same for source and regression-tests)
#
declare -r branch='OPAL-2.0'

#
# sub-directory for building and publishing results
#
declare -r repo_dir="${branch}"

#
# base directories to publish result. Final target directories are
#	${regtest_dir}/${repo_dir} 	to publish results of regression-tests
#	${unittest_dir}/${repo_dir}	to publish results of unit-tests
#
declare -r regtest_dir='/afs/psi.ch/project/amas/webhosting/opal/regressionTests'
declare -r unittest_dir='/afs/psi.ch/project/amas/webhosting/opal/unitTests'

#
# arguments passed to CMake
#
cmake_args+=( "-DCMAKE_BUILD_TYPE=RELEASE" )
cmake_args+=( "-DBUILD_OPAL_UNIT_TESTS=TRUE" )

#
# modules to load/setup build environment
#
source /opt/psi/config/profile.bash
module purge
module use unstable
module load cmake/3.10.3
module load gnuplot/5.2.7
module load Python/3.6.3

module load gcc/7.4.0
module load gsl/2.6
module load OpenBLAS/0.3.7
module load gtest/1.8.1

module load openmpi/3.1.4
module load boost/1.70.0
module load hdf5/1.10.5

module load H5hut/2.0.0rc6

#-----------------------------------------------------------------------------
# no changes should be required below this line!
declare -r publish_dir="${regtest_dir}/${repo_dir}"
declare -r publish_dir_unittests="${unittest_dir}/${repo_dir}"
declare -r cmake_args=( "${cmake_args[@]/#/--cmake-args=}" )
declare -r opal_args=( "${opal_args[@]/#/--opal-args=}" )

bash -x "${bindir}/run-tests"						\
		"${cmake_args[@]}"					\
		"${opal_args[@]}"					\
		--src-repo-url="${src_repo_url}"			\
		--tests-repo-url="${tests_repo_url}"			\
		--repo-dir=${repo_dir}					\
		--publish-dir="${publish_dir}" 				\
		--publish-dir-unittests="${publish_dir_unittests}"	\
		"$@"							\
		"${branch}"
